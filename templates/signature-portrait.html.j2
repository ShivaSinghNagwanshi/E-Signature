<style type="text/css">
  @media screen and (max-width: 480px) {
    .responsive-card { max-width: 100% !important; width: 100% !important; }
    .responsive-name { font-size: 18px !important; line-height: 24px !important; }
    .responsive-title { font-size: 13px !important; }
    .responsive-profile { width: 100% !important; max-width: 64px !important; height: auto !important; }
    .responsive-icon { width: 100% !important; max-width: {{ design.icon_size }}px !important; height: auto !important; }
  }
  @media (prefers-color-scheme: light) {
    .light-invert { filter: invert(1) brightness(0) !important; }
  }
</style>
<table cellpadding="0" cellspacing="0" border="0" width="100%" style="font-family: {{ design.font_family }}; margin: 0 auto; border-collapse: collapse;">
  <tr>
    <td align="center" style="padding: 16px;">
      <!-- Profile Hover Card (Static Email Version) -->
      <table class="responsive-card" cellpadding="0" cellspacing="0" border="0" width="320" style="
        border-radius: 24px; 
        overflow: hidden; 
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border-collapse: collapse;
      ">
        <tr>
          <td background="{{ asset_base_url }}/{{ background_filename if background_filename else profile_filename }}" valign="bottom" style="
            background-image: url('{{ asset_base_url }}/{{ background_filename if background_filename else profile_filename }}'); 
            background-size: cover; 
            background-position: center; 
            height: 384px; 
            width: 320px; 
            border-radius: 24px;
          ">
            <!-- Gradient Overlay -->
            <table cellpadding="0" cellspacing="0" border="0" width="100%" height="100%" style="height: 100%; border-collapse: collapse;">
              <tr>
                <td valign="bottom" style="
                  background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.7) 40%, transparent 100%); 
                  padding: 24px; 
                  border-radius: 0 0 24px 24px;
                ">
                  <!-- Name & Verification -->
                  <table cellpadding="0" cellspacing="0" border="0" width="100%" style="border-collapse: collapse;">
                    <tr>
                      <td align="center" style="padding-bottom: 20px;">
                            <img class="responsive-profile" src="{{ asset_base_url }}/{{ profile_filename }}" width="64" height="64" alt="{{ personal.full_name }}" style="
                              border-radius: 50%;
                              display: block;
                              object-fit: cover;
                              box-shadow: 0 4px 10px rgba(0,0,0,0.1);
                            ">
                      </td>
                    </tr>
                    <tr>
                      <td class="responsive-name" align="center" style="font-size: 20px; font-weight: 700; color: #ffffff; padding-bottom: 6px; letter-spacing: -0.5px;">
                        {{ personal.full_name }}
                        {% if verified_icon_exists %}
                        <img src="{{ asset_base_url }}/{{ icon_paths_light['verified'] }}" width="14" height="14" alt="Verified" style="vertical-align: middle; margin-left: 4px; display: inline; border: 0;">
                        {% endif %}
                      </td>
                    </tr>
                    <!-- Description -->
                    <tr>
                      <td class="responsive-title" align="center" style="font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.5; padding-bottom: 16px;">
                        {{ personal.job_title }}{% if personal.company %} at {{ personal.company }}{% endif %}
                      </td>
                    </tr>
                    {% if personal.about %}
                    <!-- Bio / About -->
                    <tr>
                      <td align="center" style="font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.4; padding-bottom: 20px; max-width: 280px; margin: 0 auto;">
                        {{ personal.about }}
                      </td>
                    </tr>
                    {% endif %}
                    <!-- Social Links -->
                    <tr>
                      <td align="center" style="padding-bottom: 20px;">
                        <table cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse; margin: 0 auto;">
                          <tr>
                            {% for icon_key in social_order %}
                            {% if social_links.get(icon_key) %}
                            <td style="padding: 0 6px;">
                              <a href="{{ social_links[icon_key] }}" target="_blank" style="text-decoration: none;">
                                <img class="light-invert responsive-icon" src="{{ asset_base_url }}/{{ icon_paths_light[icon_key] }}" width="{{ design.icon_size }}" height="{{ design.icon_size }}" alt="{{ icon_key }}" style="display: block; border: 0;">
                              </a>
                            </td>
                            {% endif %}
                            {% endfor %}
                          </tr>
                        </table>
                      </td>
                    </tr>
                    <!-- Follow / CTA Button -->
                    <tr>
                      <td>
                        <table cellpadding="0" cellspacing="0" border="0" width="100%" style="border-collapse: collapse;">
                          <tr>
                            <td align="center" style="
                              background: linear-gradient(145deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0.1) 100%); 
                              background-color: rgba(255,255,255,0.15); 
                              border: 1px solid rgba(255,255,255,0.3); 
                              box-shadow: inset 0 1px 2px rgba(255,255,255,0.3), 0 4px 12px rgba(0,0,0,0.1); 
                              border-radius: 12px; 
                              padding: 10px 16px;
                            ">
                              <a href="{{ cta.url if cta.enabled else contact.website }}" target="_blank" style="
                                color: #ffffff; 
                                text-decoration: none; 
                                font-weight: 600; 
                                font-size: 13px;
                                display: block;
                                width: 100%;
                              ">
                                {% if cta.enabled %}{{ cta.text }}{% else %}Follow +{% endif %}
                              </a>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
