                <div id="skeleton-container"></div>
                <script>
                    function fillSkeletons() {
                        const container = document.getElementById("skeleton-container");
                        const scrollContainer = container.parentElement;
                        const activeEmailHeight = scrollContainer.children[0].offsetHeight;
                        const availableHeight = scrollContainer.clientHeight - activeEmailHeight;
                        const numItems = Math.max(0, Math.floor(availableHeight / 85)) + 1;
                        let html = "";
                        for(let i = 0; i < numItems; i++) {
                            html += `<div class="px-3 py-3 border-b border-mac-border cursor-default flex gap-2 animate-drop-down-stagger" style="animation-delay: ${0.6 + ((i+1) * 0.05)}s">
                                <div class="w-[10px]"></div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-center mb-2">
                                        <div class="h-3 w-24 bg-[#333] rounded animate-pulse"></div>
                                        <div class="h-2 w-12 bg-[#2d2d2d] rounded animate-pulse"></div>
                                    </div>
                                    <div class="h-2.5 w-3/4 bg-[#333] rounded animate-pulse mb-2"></div>
                                    <div class="h-2 w-full bg-[#2d2d2d] rounded animate-pulse mb-1"></div>
                                    <div class="h-2 w-5/6 bg-[#2d2d2d] rounded animate-pulse"></div>
                                </div>
                            </div>`;
                        }
                        container.innerHTML = html;
                    }
                    document.addEventListener("DOMContentLoaded", fillSkeletons);
                    window.addEventListener("resize", fillSkeletons);
                </script>
            </div>
