            color: white;
        }
        
        /* Height-based responsiveness for Sidebar content to fit shorter viewports */
        @media (max-height: 850px) {
            .sidebar-item {
                padding: 4px 10px !important;
                margin: 1px 8px !important;
                font-size: 12px !important;
                gap: 6px !important;
