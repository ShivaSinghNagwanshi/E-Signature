                            <svg height="18" viewBox="0 0 16 16" width="18" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
                        </a>
                        <div class="h-5 w-px bg-mac-border mx-1"></div>
                    </div>
                    <div class="items-center rounded-md px-2 py-[5px] border hidden lg:flex animate-expand-search" style="animation-delay: 1.0s; width: 32px; background-color: transparent; border-color: transparent; opacity: 0;">
                        <span class="material-symbols-outlined text-[16px] text-mac-text-muted">search</span>
                        <input type="text" placeholder="Search" class="bg-transparent border-none text-xs text-white placeholder-mac-text-muted focus:ring-0 focus:outline-none outline-none w-full px-2" readonly>
                    </div>
                </div>
            </div>
            <div class="flex-grow overflow-y-auto overflow-x-hidden px-4 py-4 sm:px-6 sm:py-6 text-[13px]">
                <div class="flex gap-4">
                    <div class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center overflow-hidden border border-[#333]">
                        <img src="{{ asset_base_url }}/{{ profile_png_filename }}" alt="Profile" class="w-full h-full object-cover">
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline mb-1">
                            <span class="font-semibold text-[14px] text-white">{{ personal.full_name }}</span>
                            <span class="text-[12px] text-mac-text-muted">Today at 10:23 AM</span>
                        </div>
                        <div class="text-[13px] font-semibold text-white mb-1">Project Updates & Final Review</div>
                        <div class="text-[12px] text-mac-text-muted">
                            To: <span class="text-[#d1d1d6]">Client Name</span>
                        </div>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-mac-border my-5"></div>
                                <div class="text-[#d1d1d6] leading-relaxed email-body-content">
                    <p class="mb-4 email-body-p">Dear Client,</p>
                    <p class="mb-4 email-body-p">I've attached the latest project updates for your final review. The deliverables align with our recent discussion regarding the premium UI rollout.</p>
                    <p class="mb-6 email-body-p">Please let me know if you need any adjustments before we proceed to launch.</p>
                    <p class="mb-8 email-body-p">Best regards,</p>
                    <div class="preview-signature w-full opacity-0" id="signature-container">
                        {{ signature_html }}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        function toggleSidebar() {
            const macWindow = document.querySelector('.mac-window');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const toolbarActions = document.getElementById('toolbar-actions');
            const sidebarChildren = document.querySelectorAll('#column-1 .overflow-y-auto > div, #column-1 .overflow-y-auto > a');
            
            if (macWindow.classList.contains('sidebar-hidden')) {
                macWindow.classList.remove('sidebar-hidden');
                toggleBtn.classList.remove('flip-active');
                
                const toolbarChildren = toolbarActions.children;
                Array.from(toolbarChildren).forEach((child, index) => {
                    child.style.animation = 'none';
                    child.offsetHeight;
                    child.style.animation = null;
                    child.style.animationDelay = `${(3 - index) * 0.05}s`;
                    child.classList.remove('animate-pop-in');
                    child.classList.add('animate-pop-out');
                });
                
                setTimeout(() => {
                    toolbarActions.classList.add('lg:hidden');
                    Array.from(toolbarChildren).forEach(child => {
                        child.classList.remove('animate-pop-out');
                    });
                }, 300);
                
                sidebarChildren.forEach((child, index) => {
                    child.style.animation = 'none';
                    child.offsetHeight; 
                    child.style.animation = null;
                    child.style.animationDelay = `${0.3 + (index * 0.04)}s`;
                    child.classList.remove('animate-reverse-stagger');
                    child.classList.add('animate-drop-down-stagger');
                });
            } else {
                toggleBtn.classList.add('flip-active');
                
                sidebarChildren.forEach((child, index) => {
                    child.style.animation = 'none';
                    child.offsetHeight;
                    child.style.animation = null;
                    child.style.animationDelay = `${(index * 0.02)}s`;
                    child.classList.remove('animate-drop-down-stagger');
                    child.classList.add('animate-reverse-stagger');
                });
                
                setTimeout(() => {
                    macWindow.classList.add('sidebar-hidden');
                    toolbarActions.classList.remove('lg:hidden');
                    const toolbarChildren = toolbarActions.children;
                    Array.from(toolbarChildren).forEach((child, index) => {
                        child.style.animation = 'none';
                        child.offsetHeight;
                        child.style.animation = null;
                        child.style.animationDelay = `${index * 0.05}s`;
                        child.classList.remove('animate-pop-out');
                        child.classList.add('animate-pop-in');
                    });
                }, 300);
            }
        }

        async function copySignatureVisual(btn) {
            const sigHTML = document.querySelector('.preview-signature').innerHTML;
            const originalIcon = btn.innerText;
            try {
                const blobHtml = new Blob([sigHTML], { type: 'text/html' });
                const blobText = new Blob([sigHTML], { type: 'text/plain' });
                const data = [new window.ClipboardItem({ 'text/html': blobHtml, 'text/plain': blobText })];
                await navigator.clipboard.write(data);
                
                btn.innerText = 'check';
                setTimeout(() => { btn.innerText = originalIcon; }, 2000);
            } catch (err) {
                const container = document.createElement('div');
                container.innerHTML = sigHTML;
                document.body.appendChild(container);
                const range = document.createRange();
                range.selectNode(container);
                window.getSelection().removeAllRanges();
                window.getSelection().addRange(range);
                document.execCommand('copy');
                window.getSelection().removeAllRanges();
                document.body.removeChild(container);
                
                btn.innerText = 'check';
                setTimeout(() => { btn.innerText = originalIcon; }, 2000);
            }
        }

        async function copySignatureCode(btn) {
            const sigHTML = document.querySelector('.preview-signature').innerHTML.trim();
            const originalIcon = btn.innerText;
            try {
                await navigator.clipboard.writeText(sigHTML);
                btn.innerText = 'check';
                setTimeout(() => { btn.innerText = originalIcon; }, 2000);
            } catch (err) {
                alert('Failed to copy code.');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                document.querySelector('.mac-window').classList.remove('sidebar-hidden');
            }, 100);

            const sidebarChildren = document.querySelectorAll('#column-1 .overflow-y-auto > div, #column-1 .overflow-y-auto > a');
            sidebarChildren.forEach((child, index) => {
                child.classList.add('animate-drop-down-stagger');
                child.style.animationDelay = `${0.5 + (index * 0.04)}s`;
            });

            const headerIcons = document.querySelectorAll('#header-icons-left > span');
            headerIcons.forEach((icon, index) => {
                icon.classList.add('animate-drop-down-stagger');
                icon.style.animationDelay = `${0.5 + (index * 0.08)}s`;
            });

            const middleHeaderItems = document.querySelectorAll('.w-\\[320px\\] > .h-14 > div, .w-\\[320px\\] > .h-14 > span');
            middleHeaderItems.forEach((child, index) => {
                child.classList.add('animate-drop-down-stagger');
                child.style.animationDelay = `${0.5 + (index * 0.1)}s`;
            });

            const rightHeaderItems = document.querySelectorAll('.overflow-y-auto .flex.gap-4 > div');
            rightHeaderItems.forEach((child, index) => {
                child.classList.add('animate-drop-down-stagger');
                child.style.animationDelay = `${0.7 + (index * 0.1)}s`;
            });

            const paragraphs = document.querySelectorAll('.email-body-p');
            paragraphs.forEach(p => {
                p.setAttribute('data-text', p.innerHTML);
                p.innerHTML = '';
            });

            let currentP = 0;
            let charIndex = 0;

            function typeWriter() {
                if (currentP < paragraphs.length) {
                    const p = paragraphs[currentP];
                    const text = p.getAttribute('data-text');
                    
                    if (charIndex < text.length) {
                        p.innerHTML += text.charAt(charIndex);
                        charIndex++;
                        setTimeout(typeWriter, 5);
                    } else {
                        currentP++;
                        charIndex = 0;
                        setTimeout(typeWriter, 5);
                    }
                } else {
                    document.getElementById('signature-container').classList.add('animate-slide-up-fade');
                }
            }
            setTimeout(typeWriter, 1200);
        });
    </script>
</body>
