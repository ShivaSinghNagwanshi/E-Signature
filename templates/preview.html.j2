                font-size: 13px !important;
            }
            .px-3.pt-4.pb-1, .px-3.pt-6.pb-1 {
                padding-top: 4px !important;
                padding-bottom: 2px !important;
            }
            .px-3.pt-2.pb-1 {
                padding-top: 2px !important;
                padding-bottom: 2px !important;
            }
        }

        /* Override MSO specifics for preview rendering */
        .preview-signature table {
            border-collapse: collapse;
            margin: 0;
            padding: 0;
        }
        .preview-signature td {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        /* Prevent Tailwind from squishing signature images */
        .preview-signature img {
            max-width: none !important;
        }
        /* Transitions for Sidebar Toggle */
        #column-1 {
            transition: margin-left 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }
        .sidebar-hidden #column-1 {
            margin-left: -220px; /* Hide by pulling left */
        }
        
        /* Button Animations */
        .animate-pop-in {
            opacity: 0;
            animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        @keyframes popIn {
            0% { transform: scale(0.5); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .animate-pop-out {
            animation: popOut 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        @keyframes popOut {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(0.5); opacity: 0; }
        }
        
        .flip-active {
            transform: rotateY(180deg) scale(1.1);
        }
        
