                padding-top: 8px !important;
                padding-bottom: 2px !important;
            }
            .px-3.pt-2.pb-1 {
                padding-top: 4px !important;
                padding-bottom: 2px !important;
            }
        }
        @media (max-height: 720px) {
            .sidebar-item {
                padding: 3px 8px !important;
                margin: 1px 6px !important;
                font-size: 11px !important;
                gap: 4px !important;
            }
