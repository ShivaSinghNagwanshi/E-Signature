<style type="text/css">

  u + .body .light-invert { filter: invert(1) brightness(0) !important; }
  [data-ogsc] .light-invert { filter: invert(1) brightness(0) !important; }

  @media (prefers-color-scheme: light) {
    .light-invert { filter: invert(1) brightness(0) !important; }
  }

  @media screen and (max-width: 480px) {
    .responsive-logo { width: 45px !important; min-width: 45px !important; }
    .responsive-name { font-size: 15px !important; }
    .responsive-title { font-size: 11px !important; }
    .responsive-profile { width: 75px !important; height: auto !important; }
    .responsive-card-padding { padding: 12px 10px !important; }
    .responsive-gap { padding-left: 8px !important; padding-right: 8px !important; }
    .responsive-nowrap { white-space: normal !important; }
  }
</style>
<table cellpadding="0" cellspacing="0" border="0"
  style="border-collapse: collapse; font-size: 10px; font-family: {{ design.font_family }}; width: 100%; max-width: 600px;">
  <tbody>
    <tr>
      <td align="center" {% if background_filename %}background="{{ asset_base_url }}/{{ background_filename }}"{% endif %}
        style="line-height: 16px; font-family: {{ design.font_family }}; border-collapse: collapse; padding: 24px; border-radius: 16px; {% if background_filename %}background-image: url('{{ asset_base_url }}/{{ background_filename }}'); background-size: cover; background-position: center; background-repeat: no-repeat;{% else %}background: linear-gradient(120deg, #f6f8fd 0%, #f1f5f9 100%);{% endif %} background-color: #000000;">
                <table cellpadding="0" cellspacing="0" border="0" width="100%"
          style="border-collapse: separate; border-radius: 16px; box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.08), 0 10px 20px -5px rgba(0, 0, 0, 0.04); width: 100%;">
          <tbody>
            <tr>
              <td align="left" valign="top" class="responsive-card-padding"
                style="border-collapse: collapse; padding: 24px; border-radius: 16px 16px 0 0; border-bottom: none; backdrop-filter: blur(24px); {% if design.style == 'glassmorphism' %}background: linear-gradient(145deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.02) 100%); background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); border-top: 1px solid rgba(255,255,255,0.3); box-shadow: inset 0 1px 1px rgba(255,255,255,0.2), inset 0 0 20px rgba(255,255,255,0.1);{% else %}background: linear-gradient(145deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.6) 100%); background-color: #ffffff; border: 1px solid rgba(255,255,255,0.7); border-top: 1px solid rgba(255,255,255,0.9); box-shadow: inset 0 1px 1px rgba(255,255,255,1), inset 0 0 20px rgba(255,255,255,0.6);{% endif %}">
                                <table cellpadding="0" cellspacing="0" border="0" width="100%"
                  style="border-collapse: separate; width: 100%;">
                  <tbody>
                    <tr>
                                            <td align="center" valign="middle"
                        style="border-collapse: separate; border-radius: 14px; padding: 10px; vertical-align: middle; {% if design.style == 'glassmorphism' %}background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.05) 100%); background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); box-shadow: inset 0 1px 2px rgba(255,255,255,0.2), 0 8px 20px rgba(0,0,0,0.04), 0 2px 6px rgba(0,0,0,0.02);{% else %}background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(241,245,249,0.8) 100%); background-color: #f8fafc; border: 1px solid rgba(255,255,255,0.8); box-shadow: inset 0 2px 4px rgba(255,255,255,0.9), 0 8px 20px rgba(0,0,0,0.04), 0 2px 6px rgba(0,0,0,0.02);{% endif %}">
                        <table border="0" cellspacing="0" cellpadding="0"
                          style="border-collapse: collapse;">
                          <tbody>
                                                        {% for icon_key in social_order %}
                            {% if social_links.get(icon_key) %}
                            <tr>
                              <td align="center" style="padding: {{ '4px 0 0 0' if not loop.first else '0' }};">
                                <a href="{{ social_links[icon_key] }}" target="_blank"
                                  style="text-decoration: none; display: inline-block;">
                                  <img class="light-invert responsive-icon" alt="{{ icon_key }}"
                                    src="{{ asset_base_url }}/{{ icon_paths_light[icon_key] }}"
                                    width="{{ design.icon_size }}"
                                    height="{{ design.icon_size }}"
                                    style="display: block; border: 0; outline: none;">
                                </a>
                              </td>
                            </tr>
                            {% endif %}
                            {% endfor %}
                          </tbody>
                        </table>
                      </td>
                                            <td class="responsive-gap" style="padding-right: 18px; border-collapse: collapse;">
                      </td>
                                            <td align="left" valign="middle"
                        style="border-collapse: collapse; vertical-align: middle;">
                        <table width="100%" border="0" cellspacing="0" cellpadding="0"
                          style="border-collapse: collapse;">
                          <tbody>
                            <tr>
                              <td align="left" valign="middle"
                                style="border-collapse: collapse;">
                                <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                  style="border-collapse: collapse;">
                                  <tbody>
                                                                        <tr>
                                      <td style="padding: 0 0 4px 0; border-collapse: collapse;">
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border-collapse: collapse;">
                                          <tr>
                                            {% if assets.use_logo is not defined or assets.use_logo %}
                                            <td valign="middle" class="responsive-gap" style="padding-right: 12px; width: 1%;">
                                              <a href="{{ contact.website }}" target="_blank" style="text-decoration: none;">
                                                <img alt="{{ personal.company }}" src="{{ asset_base_url }}/{{ logo_filename_light }}" width="60" class="responsive-logo" style="display: block; border: 0; outline: none; min-width: 60px;">
                                              </a>
                                            </td>
                                            {% endif %}
                                            <td valign="middle" style="padding-left: 0;">
                                              <span class="responsive-name" style="font-weight: 800; font-style: normal; color: {{ design.text_primary }}; font-size: 18px; letter-spacing: -0.5px; font-family: {{ design.font_family }};">{{ personal.full_name }}</span>
                                              {% if verified_icon_exists %}
                                              &nbsp;<img class="light-invert" alt="Verified" src="{{ asset_base_url }}/{{ icon_paths_light['verified'] }}" width="16" height="16" style="vertical-align: text-bottom; display: inline; border: 0;">
                                              {% endif %}
                                            </td>
                                          </tr>
                                        </table>
                                      </td>
                                    </tr>
                                                                        <tr>
                                      <td style="padding: 6px 0 10px 0; border-collapse: collapse;">
                                        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse;">
                                          <tbody>
                                            <tr>
                                              <td style="width: 100%; height: 1px; background: linear-gradient(90deg, {{ design.accent_color }} 0%, transparent 100%); font-size: 0; line-height: 0;">
                                                &nbsp;
                                              </td>
                                            </tr>
                                          </tbody>
                                        </table>
                                      </td>
                                    </tr>
                                                                        <tr>
                                      <td class="responsive-nowrap" style="border-collapse: collapse; padding: 0 0 1px 0;" nowrap="">
                                        <span style="font-weight: 400; font-style: normal; color: {{ design.text_secondary }}; font-size: 12px; font-family: {{ design.font_family }};">{{ personal.job_title }}</span>
                                      </td>
                                    </tr>
                                                                        {% if personal.company %}
                                    <tr>
                                      <td class="responsive-nowrap" style="border-collapse: collapse; padding: 0 0 6px 0;" nowrap="">
                                        <span style="font-weight: 600; font-style: normal; color: {{ design.text_primary }}; font-size: 12px; font-family: {{ design.font_family }};">{{ personal.company }}</span>
                                      </td>
                                    </tr>
                                    {% endif %}
                                                                        {% if personal.email %}
                                    <tr>
                                      <td class="responsive-nowrap" style="border-collapse: collapse; padding: 0 0 1px 0;" nowrap="">
                                          <a href="mailto:{{ personal.email }}"
                                            style="text-decoration: none; font-weight: 400; font-style: normal; color: {{ design.text_secondary }}; font-size: 12px; font-family: {{ design.font_family }};">
                                            {{ personal.email }}
                                          </a>
                                      </td>
                                    </tr>
                                    {% endif %}
                                                                        {% if contact.website_display %}
                                    <tr>
                                      <td class="responsive-nowrap" style="border-collapse: collapse; padding: 0 0 2px 0;" nowrap="">
                                          <a href="{{ contact.website }}" target="_blank"
                                            style="text-decoration: none; font-weight: 400; font-style: normal; color: {{ design.accent_color }}; font-size: 12px; font-family: {{ design.font_family }};">
                                            {{ contact.website_display }}
                                          </a>
                                      </td>
                                    </tr>
                                    {% endif %}
                                  </tbody>
                                </table>
                              </td>
                                                            <td align="right" valign="middle" class="responsive-gap"
                                style="padding: 0 0 0 24px; border-collapse: collapse; vertical-align: middle; width: 1%;">
                                <img alt="{{ personal.full_name }}" class="responsive-profile"
                                  src="{{ asset_base_url }}/{{ profile_filename }}"
                                  width="{{ design.profile_size }}"
                                  {% if design.style == 'glassmorphism' %}
                                    {% if profile_is_gif %}
                                    style="display: block; box-shadow: none; outline: none;"
                                    {% else %}
                                    style="display: block; border-radius: 50%; box-shadow: 0 8px 24px rgba(0,0,0,0.15), 0 0 0 1px rgba(255,255,255,0.3); outline: none;"
                                    {% endif %}
                                  {% else %}
                                    {% if profile_is_gif %}
                                    style="display: block; box-shadow: none; outline: none;"
                                    {% else %}
                                    style="display: block; border-radius: 20px; border: 2px solid #ffffff; box-shadow: 0 8px 24px rgba(0,0,0,0.08); outline: none;"
                                    {% endif %}
                                  {% endif %}>
                              </td>
                            </tr>
                          </tbody>
                        </table>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </td>
            </tr>
          </tbody>
        </table>
                {% if cta.enabled %}
        <table cellpadding="0" cellspacing="0" border="0" width="100%"
          style="border-collapse: separate; width: 100%;">
          <tbody>
            <tr>
              <td align="center"
                style="border-radius: 0 0 16px 16px; padding: 12px 16px; backdrop-filter: blur(24px); {% if design.style == 'glassmorphism' %}background: linear-gradient(180deg, rgba(248,250,252,0.15) 0%, rgba(241,245,249,0.05) 100%); background-color: rgba(248,250,252,0.1); border: 1px solid rgba(255,255,255,0.15); border-top: 1px solid rgba(255,255,255,0.2);{% else %}background: linear-gradient(180deg, rgba(248,250,252,0.8) 0%, rgba(241,245,249,0.9) 100%); background-color: #f8fafc; border: 1px solid rgba(255,255,255,0.6); border-top: 1px solid rgba(226,232,240,0.6);{% endif %}">
                <table align="center" cellpadding="0" cellspacing="0" border="0" style="border-collapse: separate; line-height: 0px;">
                  <tbody>
                    <tr>
                      <td valign="middle" style="border-radius:2px; padding-right: 6px;">
                                                <div style="width: 6px; height: 6px; background-color: {{ design.accent_color }}; border-radius: 50%;"></div>
                      </td>
                      <td valign="middle" style="font-size: 11px; padding-right: 4px; color: {{ design.text_secondary|default('#64748b') }}; font-family: {{ design.font_family }};">
                        <a href="{{ cta.url }}" target="_blank" style="text-decoration: none; color: {{ design.text_secondary|default('#64748b') }};">
                          View <strong style="color: {{ design.text_primary|default('#000') }};">{{ cta.text|replace('Visit Portfolio', 'Portfolio') }}</strong> &rarr;
                        </a>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </td>
                    </tr>
                  </tbody>
                </table>
              </td>
            </tr>
          </tbody>
        </table>
        {% else %}
                <table cellpadding="0" cellspacing="0" border="0"
          style="border-collapse: separate;">
          <tbody>
            <tr>
              <td style="height: 1px; background-color: #e5e7eb; border-radius: 0 0 12px 12px; font-size: 0; line-height: 0;">
                &nbsp;
              </td>
            </tr>
          </tbody>
        </table>
        {% endif %}
      </td>
    </tr>
  </tbody>
</table>
